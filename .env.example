# ─── TheSportsDB ──────────────────────────────────────────────────────────────
# "3" es la key pública gratuita. Registrá una cuenta para más historial.
THESPORTSDB_API_KEY=3

# ─── API-Sports (Rugby / Selknam) ─────────────────────────────────────────────
# Free tier: 100 req/day. Registrate en https://api-sports.io
API_SPORTS_KEY=

# ─── Sync behaviour ───────────────────────────────────────────────────────────
SYNC_LOOKAHEAD_DAYS=90
SYNC_LOOKBACK_DAYS=7
SYNC_CRON_EXPRESSION=0 */6 * * *

# ─── Persistencia ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/efanxp.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/efanxp.log
